---
import Base from '../layouts/Base.astro';
import ActionLink from '../components/ActionLink.astro';
import AtomIcon from '../components/illustrations/AtomIcon.astro';
import MoleculeIcon from '../components/illustrations/MoleculeIcon.astro';
import OrganismIcon from '../components/illustrations/OrganismIcon.astro';
---

<Base title="DesignReady">
	<section class="min-h-screen flex flex-col items-center justify-center gap-10 px-6 py-24">
		<h1 class="text-5xl md:text-6xl font-bold tracking-tight text-center max-w-2xl">
			Make your design
			<span class="block text-brand">AI-ready.</span>
		</h1>

		<div class="flex flex-col gap-3 max-w-xl text-center text-text-muted leading-relaxed">
			<p>
				<span class="inline-flex items-center gap-6">
					<ActionLink href="https://github.com/designready-ai/designready-ai">
						GitHub Repo
					</ActionLink>
					<ActionLink href="https://www.figma.com/community/plugin/1619643293052051000">
						Figma plugin
					</ActionLink>
				</span>
			</p>
			<p>
				Score your components across six dimensions<br class="hidden min-[481px]:inline" />
				and fix the gaps before AI code generation.
			</p>
		</div>

		<div class="flex items-center gap-6">
			<span class="text-atom"><AtomIcon size={28} /></span>
			<span class="text-molecule"><MoleculeIcon size={28} /></span>
			<span class="text-organism"><OrganismIcon size={28} /></span>
		</div>
	</section>
</Base>
